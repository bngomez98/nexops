# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (set to IDs from your Stripe dashboard)
# Annual subscription ($59/mo, billed as $708/yr)
STRIPE_PRICE_ID_HOMEOWNER_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_ANNUAL=price_...
# Monthly subscription ($79/mo)
STRIPE_PRICE_ID_HOMEOWNER_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_MONTHLY=price_...
# Elite plan ($199/mo)
STRIPE_PRICE_ID_CONTRACTOR_ELITE=price_...

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexusoperations.org
