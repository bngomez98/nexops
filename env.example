# ─── Core App URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional server-side fallback if NEXT_PUBLIC_SITE_URL is not set
SITE_URL=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only fallbacks used by middleware/server routes
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (set to IDs from your Stripe dashboard)
# Annual subscription — $59/mo billed annually ($708/yr)
STRIPE_PRICE_ID_HOMEOWNER_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_ANNUAL=price_...
# Monthly subscription — $79/mo, cancel anytime
STRIPE_PRICE_ID_HOMEOWNER_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_MONTHLY=price_...
# Elite plan — $199/mo
STRIPE_PRICE_ID_CONTRACTOR_ELITE=price_...

# ─── Neon / Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_DATABASE=
NEON_DATABASE_URL=

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Google Customer Reviews ──────────────────────────────────────────────────
# Numeric merchant ID from your Google Merchant Center account
NEXT_PUBLIC_GOOGLE_MERCHANT_ID=

# -----------------------------------------------------------------------------
# Zendesk
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ZENDESK_KEY=
