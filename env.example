# ─── Core App URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional server-side fallback if NEXT_PUBLIC_SITE_URL is not set
SITE_URL=

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Keep new automation features off by default until explicitly enabled.
NEXT_PUBLIC_AUTOMATION_ENABLED=false
# Optional server-only override (takes precedence when set)
AUTOMATION_ENABLED=
# Required for /api/automation/categorize-request (AI SDK OpenAI provider)
OPENAI_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://fsxcqohqvuvapbmfcvnu.supabase.co
# New publishable key name (preferred, from Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZzeGNxb2hxdnV2YXBibWZjdm51Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQwNTU4MDQsImV4cCI6MjA4OTYzMTgwNH0.Y6UbQhccBdoRINrZ3WeXdR7ek9v6OtS_7Zu-OljXZNc
# Expo aliases (supported fallback names)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
# Legacy anon key name (still supported as fallback)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only fallbacks used by middleware/server routes
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZzeGNxb2hxdnV2YXBibWZjdm51Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDA1NTgwNCwiZXhwIjoyMDg5NjMxODA0fQ.-2wtXZK-qIkT1tDQIEVOp5SvoOyMzjY8jzVm5pn5cVk
SUPABASE_PROJECT_REF=fsxcqohqvuvapbmfcvnu
SUPABASE_ACCESS_TOKEN=
# Optional Supabase local MCP endpoint configuration
SUPABASE_MCP_URL=
# Optional migration override used by scripts/migrate.mjs (default: setup.sql).
# After setup.sql, also run 017_nexus_business_model.sql for geo/SLA/lead-credits.
SUPABASE_MIGRATION_FILE=setup.sql

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_API_VERSION=2024-12-18

# Stripe Price IDs (set to IDs from your Stripe dashboard)
# Annual subscription — $59/mo billed annually ($708/yr)
STRIPE_PRICE_ID_HOMEOWNER_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_ANNUAL=price_...
# Monthly subscription — $79/mo, cancel anytime
STRIPE_PRICE_ID_HOMEOWNER_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_CONTRACTOR_PRO_MONTHLY=price_...
# Elite plan — $199/mo
STRIPE_PRICE_ID_CONTRACTOR_ELITE=price_...

# Default contractor subscription price in cents (fallback: 7900 = $79/mo)
NEXT_PUBLIC_CONTRACTOR_SUBSCRIPTION_PRICE_CENTS=7900

# ─── Neon / Postgres (legacy fallback; Supabase is primary) ─────────────────────
# Set automatically by the Vercel–Neon integration for project nexusoperations.
# Pooled connection (PgBouncer) — use for normal query traffic.
DATABASE_URL=postgresql://neondb_owner:password@your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct (unpooled) connection — use for migrations and DDL statements.
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:password@your-endpoint.region.aws.neon.tech/neondb?sslmode=require
# Legacy / alternate variable names (optional fallbacks)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
NEON_DATABASE_URL=

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Google Customer Reviews ──────────────────────────────────────────────────
# Numeric merchant ID from your Google Merchant Center account
NEXT_PUBLIC_GOOGLE_MERCHANT_ID=
# Google Analytics 4 measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Zendesk ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ZENDESK_KEY=

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
# Verified sending address (must match a domain verified in Resend)
RESEND_FROM_EMAIL=Nexus Operations <noreply@nexusoperations.org>

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel Cron invocations (set same value in Vercel dashboard).
# Guards: /api/cron/document-expiry, /api/cron/invoice-maintenance, /api/cron/sla-sweep.
CRON_SECRET=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for AI chat (/api/ai/chat), insights (/api/ai/insights), and
# automation categorization (/api/automation/categorize-request).
OPENAI_API_KEY=sk-...

# ─── Business-model tuning (optional overrides) ───────────────────────────────
# Nexus marketplace fee rates by urgency tier (fraction, 0 <= x <= 1).
# If unset, defaults come from lib/business-logic.ts: 0.25 / 0.30 / 0.35.
NEXUS_FEE_RATE_ROUTINE=
NEXUS_FEE_RATE_URGENT=
NEXUS_FEE_RATE_EMERGENCY=

# Default invoice net-terms (days) applied when contractor doesn't pass `due_days`.
NEXUS_INVOICE_DUE_DAYS_DEFAULT=15

# Primary dispatch region (bounding circle centroid). Topeka, KS metro by default.
NEXT_PUBLIC_DISPATCH_REGION_LAT=39.0473
NEXT_PUBLIC_DISPATCH_REGION_LNG=-95.6752
NEXT_PUBLIC_DISPATCH_REGION_RADIUS_MILES=30
