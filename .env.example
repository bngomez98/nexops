# ─────────────────────────────────────────────────────────────────────────────
# Nexus Operations — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Found in: Stripe dashboard → Developers → API keys
#
# SANDBOX (test mode) — use during development and testing.
# Keys start with sk_test_ (secret) and pk_test_ (publishable).
# No real charges occur; use Stripe test card numbers (e.g. 4242 4242 4242 4242).
#
# LIVE (production) — use only when accepting real payments.
# Keys start with sk_live_ (secret) and pk_live_ (publishable).
# Switch at: https://dashboard.stripe.com/test/apikeys → "Switch to live mode"
#
# For local development, use your sandbox keys:
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — found in: Stripe dashboard → Developers → Webhooks → Signing secret
# For local dev, run: stripe listen --forward-to localhost:3000/api/stripe/webhooks
# and use the printed webhook signing secret below.
STRIPE_WEBHOOK_SECRET=whsec_...

# Customer Portal direct login URL — found in: Stripe dashboard → Billing → Customer portal
# Used as a fallback when a portal session cannot be created via the API.
# Sandbox (test) URLs contain "test_" in the path; live URLs do not.
# Example sandbox: https://billing.stripe.com/p/login/test_xxxxxxxxxxxx
# Example live:    https://billing.stripe.com/p/login/xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/test_...

# Subscription price IDs — found in: Stripe dashboard → Products
# Create two recurring prices (monthly + annual) in sandbox first, then live.
# Sandbox price IDs start with price_ and are separate from live price IDs.
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_...

# ── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexusoperations.org

# ── Vercel Edge Config (optional — used for /welcome route) ──────────────────
# Found in: Vercel dashboard → Storage → Edge Config
EDGE_CONFIG=

# ── Development overrides ────────────────────────────────────────────────────
# Supabase auth redirect URL for local dev (e.g. http://localhost:3000)
# Leave blank in production — NEXT_PUBLIC_SITE_URL is used instead
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=
