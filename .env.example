# ─────────────────────────────────────────────────────────────────────────────
# Nexus Operations — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Found in: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret — found in: Stripe dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs — found in: Stripe dashboard → Products
# Create two recurring prices (monthly + annual) and paste the price IDs here
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_...

# ── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexusoperations.org

# ── Vercel Edge Config (optional — used for /welcome route) ──────────────────
# Found in: Vercel dashboard → Storage → Edge Config
EDGE_CONFIG=

# ── Development overrides ────────────────────────────────────────────────────
# Supabase auth redirect URL for local dev (e.g. http://localhost:3000)
# Leave blank in production — NEXT_PUBLIC_SITE_URL is used instead
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=
