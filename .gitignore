# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

# package manager caches / stores
.npm
.pnpm-store/
.yarn/cache
.yarn/install-state.gz

# lockfiles from other package managers (this project uses pnpm)
package-lock.json
yarn.lock
npm-shrinkwrap.json
# NOTE: pnpm-lock.yaml MUST be committed — do not add it here.

# testing
coverage
*.lcov

# next.js
/.next/
/out/
.swc/

# production
/build
dist

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*
logs
*.log

# env files (keep env.example / .env.example committed)
.env
.env.*
!.env.example
!env.example

# vercel
.vercel

# turbo
.turbo

# typescript
*.tsbuildinfo
next-env.d.ts

# misc
.DS_Store
*.pem

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
Thumbs.db
