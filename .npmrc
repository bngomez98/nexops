# This project uses pnpm. See package.json#packageManager.
engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
# Require the lockfile to be in sync with package.json
prefer-frozen-lockfile=true
# Ensure a single, deterministic lockfile at the workspace root
shared-workspace-lockfile=true
# Keep save-exact off — rely on semver ranges in package.json
save-exact=false
